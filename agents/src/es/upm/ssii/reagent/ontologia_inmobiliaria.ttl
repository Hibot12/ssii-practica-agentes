@prefix : <http://www.ssii.upm.es/inmobiliaria#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

### Modelo

:Vivienda rdf:type owl:Class .

:Oferta rdf:type owl:Class ;
    rdfs:subClassOf :Vivienda .

:ParaReformar rdf:type owl:Class ; 
    rdfs:subClassOf :Vivienda .

:Descartado rdf:type owl:Class ;
    rdfs:subClassOf :Vivienda .

:Ubicacion rdf:type owl:Class .

:tieneUbicacion rdf:type owl:ObjectProperty ;
    rdfs:domain :Vivienda ;
    rdfs:range :Ubicacion .

:precio rdf:type owl:DatatypeProperty ;
    rdfs:domain :Vivienda ;
    rdfs:range xsd:integer .

:precioM2 rdf:type owl:DatatypeProperty ;
    rdfs:domain :Vivienda ;
    rdfs:range xsd:integer .

:superficieM2 rdf:type owl:DatatypeProperty ;
    rdfs:domain :Vivienda ;
    rdfs:range xsd:integer .

:habitaciones rdf:type owl:DatatypeProperty ;
    rdfs:domain :Vivienda ;
    rdfs:range xsd:integer .

:banos rdf:type owl:DatatypeProperty ;
    rdfs:domain :Vivienda ;
    rdfs:range xsd:integer .

:tienePiscina rdf:type owl:DatatypeProperty ;
    rdfs:domain :Vivienda ;
    rdfs:range xsd:boolean .

:tieneTerraza rdf:type owl:DatatypeProperty ;
    rdfs:domain :Vivienda ;
    rdfs:range xsd:boolean .

:cercaPlaya rdf:type owl:DatatypeProperty ;
    rdfs:domain :Vivienda ;
    rdfs:range xsd:boolean .

:distanciaAeropuerto rdf:type owl:DatatypeProperty ;
    rdfs:domain :Vivienda ;
    rdfs:range xsd:decimal .

:ciudad rdf:type owl:DatatypeProperty ;
    rdfs:domain :Ubicacion ;
    rdfs:range xsd:string .


### Datos

